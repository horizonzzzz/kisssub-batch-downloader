{
  "name": "anime-bt-batch-downloader",
  "displayName": "Anime BT Batch",
  "version": "1.3.0",
  "private": true,
  "license": "MIT",
  "description": "Browser extension for batching downloads from supported anime BT source pages into qBittorrent.",
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "pnpm build && playwright test",
    "test:all": "pnpm typecheck && pnpm test && pnpm test:e2e"
  },
  "manifest": {
    "name": "Anime BT Batch",
    "version": "1.3.0",
    "description": "Select posts from supported anime BT source pages, resolve real download links, and send them to qBittorrent in one batch.",
    "minimum_chrome_version": "114",
    "permissions": [
      "storage",
      "tabs",
      "scripting"
    ],
    "host_permissions": [
      "http://www.kisssub.org/*",
      "https://www.kisssub.org/*",
      "http://*/*",
      "https://*/*"
    ],
    "action": {
      "default_title": "Anime BT Batch"
    }
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.13.2",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.38",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^29.0.1",
    "plasmo": "^0.90.5",
    "postcss": "^8.5.8",
    "sass": "^1.93.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
